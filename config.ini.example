[app]
name = SlovíčkoPamatovák
version = 0.2.0
secret_key =
debug = true
host = 0.0.0.0
port = 5001

[database]
uri = sqlite:///slovickopamatovak.db

[openai]
api_key =
model = gpt-4o-mini

[languages]
# kód = Název (jeden jazyk na řádek)
cs = Čeština
es = Španělština
en = Angličtina
de = Němčina
fr = Francouzština
it = Italština
pt = Portugalština
ru = Ruština
pl = Polština
sk = Slovenština
nl = Holandština
uk = Ukrajinština
hr = Chorvatština
ja = Japonština
zh = Čínština
ko = Korejština
ar = Arabština
tr = Turečtina
other = Jiný

[defaults]
lang_a = cs
lang_b = es
min_password_length = 4
